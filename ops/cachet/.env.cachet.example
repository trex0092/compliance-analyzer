# Cachet status page environment — copy to .env.cachet and fill in.
# Never commit .env.cachet (it's in .gitignore).

# Generate with: openssl rand -base64 32 | sed 's/^/base64:/'
CACHET_APP_KEY=base64:REPLACE_ME_WITH_32_BYTE_KEY
CACHET_APP_URL=https://status.example.com

POSTGRES_DB=cachet
POSTGRES_USER=cachet
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD
