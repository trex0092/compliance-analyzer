# Asana Integration
ASANA_TOKEN=your-asana-personal-access-token
ASANA_PROXY_URL=https://your-proxy.netlify.app

# AI Integration (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Email Notifications (optional — configure to enable workflow email alerts)
EMAIL_SERVICE_URL=https://your-email-service-endpoint
EMAIL_FROM=compliance@yourcompany.com
EMAIL_TO_CO=compliance-officer@yourcompany.com

# Netlify (set automatically by Netlify)
# NETLIFY_BLOBS_CONTEXT=
