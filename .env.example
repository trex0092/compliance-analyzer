# ============================================================================
# Compliance Analyzer — Environment Variables
# ============================================================================
#
# Copy this file to `.env` for local development. For Netlify production,
# set each variable in: Site → Site settings → Environment variables.
# Or via CLI: `netlify env:set KEY value`
#
# Variables marked [REQUIRED] block boot. [OPTIONAL] degrade gracefully.
# Variables marked [STUB-OK] return a "not configured" status when absent
# instead of failing — the corresponding feature is dormant until set.
#
# After editing, validate with: `npm run test` (some env vars are checked
# at boot via src/utils/envCheck.ts).
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────
# CORE — Asana integration (all-tier baseline)
# ─────────────────────────────────────────────────────────────────────────

# [REQUIRED FOR ASANA] Personal access token for the Asana API.
# Get from: https://app.asana.com/0/my-apps
ASANA_TOKEN=your-asana-personal-access-token

# [OPTIONAL] Proxy URL when running the SPA against a Netlify-hosted Asana
# proxy. Leave blank to call Asana directly with ASANA_TOKEN.
ASANA_PROXY_URL=https://your-proxy.netlify.app

# [REQUIRED FOR CRONS] Workspace GID — used by the user resolver +
# scheduled monitoring functions.
ASANA_WORKSPACE_GID=

# [OPTIONAL] Default assignee for cron-created tasks (case-insensitive
# substring match against workspace user names).
ASANA_DEFAULT_ASSIGNEE_NAME=Luisa Fernanda

# [REQUIRED FOR CRONS] Default project for screening tasks created by
# the scheduled cron when no per-customer project is configured.
# Labelled "Screening Command — Sanctions" in the production workspace.
ASANA_SCREENINGS_PROJECT_GID=1213759768596515

# [REQUIRED FOR /workbench Asana integration] Project GID for the
# "Workbench — MLRO Console" board. Tasks created from the workbench
# compliance-task surface post here. FDL Art.20-21, Art.24.
ASANA_WORKBENCH_PROJECT_GID=

# [REQUIRED FOR /logistics Asana integration] Project GID for the
# "Logistics — Shipments" board. Shipment-risk alerts, LBMA-cert
# expiries and CAHRA hits post here. FDL Art.20, LBMA RGG v9.
ASANA_LOGISTICS_PROJECT_GID=

# [REQUIRED FOR /routines Asana integration] Project GID for the
# "Routines — Daily / Weekly / Monthly" board. Scheduled-cron
# heartbeat tasks and cron-failure tasks post here.
ASANA_ROUTINES_PROJECT_GID=

# [REQUIRED FOR AI GOVERNANCE CRON] Asana project that receives the
# daily AI Governance self-audit watchdog tasks. The cron at
# netlify/functions/ai-governance-self-audit-cron.mts skips when unset.
ASANA_AI_GOVERNANCE_PROJECT_GID=


# ─────────────────────────────────────────────────────────────────────────
# Asana custom field GIDs — needed for compliance custom-field rollups
# ─────────────────────────────────────────────────────────────────────────
# Each block maps a compliance enum to an Asana custom field + option GID.
# Bootstrap via `npm run script -- scripts/asana-cf-bootstrap.ts`.
# All [STUB-OK] — missing GIDs silently drop the field from task payloads.

# Risk level (enum field)
ASANA_CF_RISK_LEVEL_GID=
ASANA_CF_RISK_LEVEL_CRITICAL=
ASANA_CF_RISK_LEVEL_HIGH=
ASANA_CF_RISK_LEVEL_MEDIUM=
ASANA_CF_RISK_LEVEL_LOW=

# Verdict (enum field)
ASANA_CF_VERDICT_GID=
ASANA_CF_VERDICT_PASS=
ASANA_CF_VERDICT_FLAG=
ASANA_CF_VERDICT_ESCALATE=
ASANA_CF_VERDICT_FREEZE=

# Case id (text field)
ASANA_CF_CASE_ID_GID=

# Deadline type (enum field)
ASANA_CF_DEADLINE_TYPE_GID=
ASANA_CF_DEADLINE_TYPE_STR=
ASANA_CF_DEADLINE_TYPE_CTR=
ASANA_CF_DEADLINE_TYPE_CNMR=
ASANA_CF_DEADLINE_TYPE_DPMSR=
ASANA_CF_DEADLINE_TYPE_EOCN=

# Numeric fields
ASANA_CF_DAYS_REMAINING_GID=
ASANA_CF_CONFIDENCE_GID=

# Text fields
ASANA_CF_REGULATION_GID=

# CDD push side-channel fields (consumed by
# src/services/cddAsanaCustomFieldPush.ts). Provisioned by
# `npm run asana:bootstrap:cf` — paste the export lines back here.
ASANA_CF_CUSTOMER_NAME_GID=
ASANA_CF_JURISDICTION_GID=
ASANA_CF_UBO_COUNT_GID=

# PEP flag (enum field — provisioned by asana-cf-bootstrap.ts)
ASANA_CF_PEP_FLAG_GID=
ASANA_CF_PEP_FLAG_CLEAR=
ASANA_CF_PEP_FLAG_POTENTIAL=
ASANA_CF_PEP_FLAG_MATCH=

# ---------------------------------------------------------------------------
# Phase 19 W-E — Regulatory citation block escape hatch.
# ---------------------------------------------------------------------------
# Every task dispatched via asanaSync.ts has the canonical Phase 19 W-E
# regulatory citation block appended to its notes by default. Set this
# to "1" (or "true" / "yes") to disable the append without a code
# revert. Enricher source: src/services/regulatoryCitationEnricher.ts.
# Wiring: src/services/asanaSync.ts (maybeAppendCitation).
#
# Leave blank in production. Intended use: emergency rollback only.
ASANA_CITATION_BLOCK_DISABLED=

# ---------------------------------------------------------------------------
# Phase 19 W-A — Per-tenant rate limit escape hatch.
# ---------------------------------------------------------------------------
# asanaQueue.processRetryQueue checks a per-tenant token bucket before
# each createAsanaTask call. Set to "1" to bypass the bucket and send
# every retry attempt immediately. Default ENABLED. Bucket source:
# src/services/asanaPerTenantRateLimit.ts. Wiring:
# src/services/asanaQueue.ts.
#
# Intended use: incident rollback only, e.g. when a downstream Asana
# outage recovers and a burst-drain of the retry queue is preferable
# to the per-tenant pacing.
ASANA_RATE_LIMIT_DISABLED=

# ---------------------------------------------------------------------------
# Phase 19 W-B — Server-side tenant project resolver escape hatch.
# ---------------------------------------------------------------------------
# asanaSync's getComplianceProject / getWorkflowProject route through
# resolveTenantProject (three-tier chain) by default. Set to "1" to
# revert to the pre-W-B direct COMPANY_REGISTRY lookup. Default
# ENABLED. Resolver source: src/services/asanaTenantProjectResolver.ts.
# Wiring: src/services/asanaSync.ts.
#
# Intended use: emergency rollback if the resolver introduces a
# regression on a specific tenant.
ASANA_WB_RESOLVER_DISABLED=

# ---------------------------------------------------------------------------
# Phase 19 W-C — Reconcile cron controls.
# ---------------------------------------------------------------------------
# The reconcile cron runs every 5 minutes and enumerates every tenant
# in COMPANY_REGISTRY. Default: the cron ticks and writes audit rows
# but the snapshot reads are stubbed (no reconciliation actions).
#
# ASANA_RECONCILE_CRON_DISABLED=1 makes the cron a no-op entirely
# (exits with { ok: true, skipped: 'cron_disabled_via_env' }).
ASANA_RECONCILE_CRON_DISABLED=

# ASANA_RECONCILE_LIVE_READS_ENABLED=1 turns on live snapshot reads:
# brain side scans asana-plans blobs (last 7 days) and Asana side
# uses listProjectTasks() with heuristic name-based caseId match.
# Opt-in only — review the first audit cycles' match-quality numbers
# (plansForTenant, asanaTasksMatched) before leaving this on in
# production. Cron source:
# netlify/functions/asana-reconcile-cron.mts.
ASANA_RECONCILE_LIVE_READS_ENABLED=

# ---------------------------------------------------------------------------
# Phase 19 W-D — Bootstrap state recording escape hatch.
# ---------------------------------------------------------------------------
# setup-asana-bootstrap writes a BootstrapState record to
# asana-tenant-bootstrap-state / tenant:<id>.json after every
# provisioning run so /api/asana/bootstrap-plan can report progress.
# Set to "1" to skip the state write; the existing setup-audit row
# continues to land. Default ENABLED. Wiring:
# netlify/functions/setup-asana-bootstrap.mts (two try/catch blocks).
#
# Intended use: emergency rollback if the state-write itself
# introduces noise in the blob store.
ASANA_WD_STATE_RECORDING_DISABLED=

# Awaiting Manual Action chip (enum field — Tier-4 #13). Set
# automatically on freeze verdicts so the MLRO sees a red chip on
# the task card prompting them to execute the freeze in the bank
# portal manually. Provisioned by asana-cf-bootstrap.ts.
ASANA_CF_MANUAL_ACTION_GID=
ASANA_CF_MANUAL_ACTION_PENDING=
ASANA_CF_MANUAL_ACTION_DONE=


# ─────────────────────────────────────────────────────────────────────────
# Cross-project / audit-log Asana destinations
# ─────────────────────────────────────────────────────────────────────────
# These two projects live OUTSIDE the per-customer projects and
# aggregate compliance signals across the entire workspace. Both are
# [STUB-OK] — when unset, the cross-project mirror and audit-log
# mirror return 'unconfigured' and become no-ops.

# Central MLRO triage project — receives a mirrored task for every
# blocked / freeze / escalated case across all customer projects.
# Also receives Asana status_updates from the three briefing crons
# (morning-briefing, sanctions-watch, cdd-weekly-status) via
# src/services/mlroAsanaDispatch.ts. If unset, the briefing crons
# skip the Asana post and persist the report to the blob store only
# — recommended for local dev.
# Create manually in Asana, then paste the GID here.
ASANA_CENTRAL_MLRO_PROJECT_GID=

# Compliance audit log project — receives a mirrored task for every
# entry written to the dispatch audit log. Required for the FDL
# Art.24 10-year retention guarantee outside localStorage.
ASANA_AUDIT_LOG_PROJECT_GID=

# ---------------------------------------------------------------------------
# Sanctions manual-upload token
# ---------------------------------------------------------------------------

# Shared secret for the two sanctions operator endpoints:
#   - POST /api/sanctions/eocn-upload      — manual UAE EOCN snapshot upload
#   - GET  /api/sanctions/feed-debug       — raw upstream feed diagnosis
# The upload endpoint REQUIRES this env var (writes are never unauth'd).
# The feed-debug endpoint is unauth'd when this env var is absent —
# set it in production to gate operator diagnostics behind the token.
# Generate a strong random value (e.g. `openssl rand -hex 32`).
SANCTIONS_UPLOAD_TOKEN=

# Inspector evidence project — Tier-4 #14. Receives a sanitised
# mirror of every compliance-action audit entry (freeze, escalate,
# STR/SAR filing, four-eyes invocation, dispatch errors). PII,
# internal MLRO drafting notes, and operational state are
# intentionally omitted from this view. Provisioned by
# `npm run asana:bootstrap:inspector -- --apply`. Operator must
# manually share the project read-only with regulator inspectors
# after creation (Asana doesn't expose per-member view-only via API).
ASANA_INSPECTOR_PROJECT_GID=

# Optional team GID for the inspector project. When set, the
# bootstrap script creates the project under this team. When unset,
# Asana places it in the workspace's default location.
ASANA_INSPECTOR_TEAM_GID=

# Public base URL of the deployed analyzer — used by
# `npm run asana:bootstrap:webhooks` to compute the receiver target.
# If unset, the webhook bootstrap falls back to HAWKEYE_BRAIN_URL.
PUBLIC_BASE_URL=https://hawkeye-sterling-v2.netlify.app


# ─────────────────────────────────────────────────────────────────────────
# Server-side authentication
# ─────────────────────────────────────────────────────────────────────────

# [REQUIRED FOR PRODUCTION] Bearer token for POST /api/brain.
# Generate with: openssl rand -hex 24
# MUST be set in BOTH Netlify env vars AND locally for the orchestrator.
# Same token authenticates the toast stream poller in the SPA.
HAWKEYE_BRAIN_TOKEN=REPLACE_ME_WITH_32_HEX_CHARS

# [REQUIRED FOR FOUR-EYES] At least 2 entries, comma-separated,
# UNLESS HAWKEYE_SOLO_MLRO_MODE=true (see below). Each entry:
# <user-id>:<32-hex-key>
# Generate keys with: openssl rand -hex 16
HAWKEYE_APPROVER_KEYS=user-mlro-primary:REPLACE_ME,user-mlro-deputy:REPLACE_ME

# [REQUIRED FOR SETUP WIZARD] Second factor (TOTP, RFC 6238) for
# every POST /api/setup/* endpoint. The setup wizard (setup.html)
# and every setup-*.mts Netlify function require both the bearer
# token above AND a current 6-digit code from an authenticator app
# derived from this secret.
#
# Generate a base32 secret and add it to an authenticator app
# (Google Authenticator, 1Password, Bitwarden, Authy):
#   openssl rand -base32 20 | tr -d '=' | tr -d '\n'
#
# In the authenticator app, create a new account with:
#   Type:      Time-based (TOTP)
#   Issuer:    Hawkeye Sterling (or your firm name)
#   Account:   MLRO
#   Secret:    <the base32 string you just generated>
#   Algorithm: SHA1
#   Digits:    6
#   Period:    30 seconds
#
# Store the secret ONLY in a password manager (1Password, Bitwarden)
# and in Netlify env vars — nowhere else. Rotate by regenerating.
#
# Regulatory basis: Cabinet Res 134/2025 Art.5 (risk appetite),
# Art.19 (internal review).
SETUP_MFA_TOTP_SECRET=REPLACE_ME_WITH_BASE32_TOTP_SECRET

# [OPTIONAL] Solo-MLRO mode (Tier-1 #7) — set to 'true' when your
# operation has only one MLRO and no deputy. The dispatcher will
# accept a 1-entry HAWKEYE_APPROVER_KEYS pool, but the approvals
# API enforces a cooldown between the same MLRO's two votes so the
# fresh-eyes principle of Cabinet Res 134/2025 Art.19 is preserved
# (the second vote MUST land on a different day). Default: false.
HAWKEYE_SOLO_MLRO_MODE=false

# [OPTIONAL] Cooldown in hours between the two solo-MLRO votes.
# Default: 24 (one calendar day). Clamped to [1, 168] (one hour to
# one week) so a misconfiguration can never produce a no-op cooldown.
HAWKEYE_SOLO_MLRO_COOLDOWN_HOURS=24

# [REQUIRED FOR PRODUCTION] Server-side signing secret.
# Generate with: openssl rand -hex 32
AUTH_SIGNING_SECRET=your-random-32-byte-hex-secret

# Public URL of the deployed brain endpoint.
HAWKEYE_BRAIN_URL=https://hawkeye-sterling-v2.netlify.app

# [REQUIRED FOR /api/brain/zk-cross-tenant] Shared salt used by the
# zk cross-tenant attestation module. This salt is NOT a secret —
# the FIU circular publishes one canonical value per version, and
# every tenant in the scheme must configure the identical string so
# that their commitment hashes collide on identical observations.
# Minimum 16 chars; generate with: openssl rand -hex 16
#
# The zk module only emits SHA3-512 commitments; the raw subjectKey
# never leaves the tenant. See src/services/zkCrossTenantAttestation.ts
# for the preimage format.
HAWKEYE_CROSS_TENANT_SALT=REPLACE_ME_WITH_FIU_PUBLISHED_SALT


# ─────────────────────────────────────────────────────────────────────────
# AI / LLM integration (optional)
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key


# ─────────────────────────────────────────────────────────────────────────
# Notification bridge (Tier 4 of the autopilot pass)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] Microsoft Teams incoming webhook URL. When unset, the
# notificationBridge silently drops Teams cards.
TEAMS_WEBHOOK_URL=

# [OPTIONAL] Email channel — the legacy workflow engine reads these.
EMAIL_SERVICE_URL=https://your-email-service-endpoint
EMAIL_FROM=compliance@yourcompany.com
EMAIL_TO_CO=compliance-officer@yourcompany.com


# ─────────────────────────────────────────────────────────────────────────
# Regulatory feeds (Tier D of the autopilot pass)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] EOCN sanctions feed URL. When unset, eocnDeltaWatcher returns
# zero deltas and the cron does nothing.
EOCN_FEED_URL=

# [STUB-OK] UAE FIU goAML portal API key — needed for the FIU
# acknowledgement auto-ingest path. Set to "STUB" for plan-only mode.
GOAML_PORTAL_API_KEY=
GOAML_PORTAL_BASE_URL=https://goaml.uaefiu.gov.ae/api


# ─────────────────────────────────────────────────────────────────────────
# Banking rail integration (Tier D — auto-freeze executor)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] Banking rail freeze API key. Without it, autoFreezeExecutor
# returns 'unconfigured' and the MLRO must freeze via the bank portal.
# Set to "STUB" for plan-only mode (returns the FreezePlan but doesn't
# call the real API).
BANKING_FREEZE_API_KEY=
BANKING_FREEZE_BASE_URL=https://banking-rail.example.com/freeze


# ─────────────────────────────────────────────────────────────────────────
# Spot price feeds (metals trading + Reuters Refinitiv adapter)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] Reuters Refinitiv pricing API. When unset the adapter
# returns 'unconfigured' and the price oracle stays on its 3 free
# aggregators.
REUTERS_REFINITIV_API_KEY=
REUTERS_REFINITIV_BASE_URL=https://api.refinitiv.com/data/pricing/v1

# [OPTIONAL] Free metals price API — uses 'demo' key with severe rate
# limits when unset.
METAL_PRICE_API_KEY=your-metalpriceapi-key


# ─────────────────────────────────────────────────────────────────────────
# Trading agents (optional)
# ─────────────────────────────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=your-hyperliquid-private-key
HYPERLIQUID_VAULT_ADDRESS=your-hyperliquid-vault-address
HYPERLIQUID_NETWORK=testnet


# ─────────────────────────────────────────────────────────────────────────
# Cachet status page (optional)
# ─────────────────────────────────────────────────────────────────────────
# CACHET_BASE_URL=https://status.example.com
# CACHET_API_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# GitHub integration (optional — used by managed agents)
# ─────────────────────────────────────────────────────────────────────────
# Fine-grained PAT scoped to repo + issues + pull_requests on the
# compliance-analyzer repo.
# GITHUB_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# Netlify (set automatically by Netlify, do not set locally)
# ─────────────────────────────────────────────────────────────────────────
# NETLIFY_BLOBS_CONTEXT=
