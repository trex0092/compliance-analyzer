# ============================================================================
# Compliance Analyzer — Environment Variables
# ============================================================================
#
# Copy this file to `.env` for local development. For Netlify production,
# set each variable in: Site → Site settings → Environment variables.
# Or via CLI: `netlify env:set KEY value`
#
# Variables marked [REQUIRED] block boot. [OPTIONAL] degrade gracefully.
# Variables marked [STUB-OK] return a "not configured" status when absent
# instead of failing — the corresponding feature is dormant until set.
#
# After editing, validate with: `npm run test` (some env vars are checked
# at boot via src/utils/envCheck.ts).
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────
# CORE — Asana integration (all-tier baseline)
# ─────────────────────────────────────────────────────────────────────────

# [REQUIRED FOR ASANA] Personal access token for the Asana API.
# Get from: https://app.asana.com/0/my-apps
ASANA_TOKEN=your-asana-personal-access-token

# [OPTIONAL] Proxy URL when running the SPA against a Netlify-hosted Asana
# proxy. Leave blank to call Asana directly with ASANA_TOKEN.
ASANA_PROXY_URL=https://your-proxy.netlify.app

# [REQUIRED FOR CRONS] Workspace GID — used by the user resolver +
# scheduled monitoring functions.
ASANA_WORKSPACE_GID=

# [OPTIONAL] Default assignee for cron-created tasks (case-insensitive
# substring match against workspace user names).
ASANA_DEFAULT_ASSIGNEE_NAME=Luisa Fernanda

# [REQUIRED FOR CRONS] Default project for screening tasks created by
# the scheduled cron when no per-customer project is configured.
ASANA_SCREENINGS_PROJECT_GID=1213759768596515

# [REQUIRED FOR AI GOVERNANCE CRON] Asana project that receives the
# daily AI Governance self-audit watchdog tasks. The cron at
# netlify/functions/ai-governance-self-audit-cron.mts skips when unset.
ASANA_AI_GOVERNANCE_PROJECT_GID=


# ─────────────────────────────────────────────────────────────────────────
# Asana custom field GIDs — needed for compliance custom-field rollups
# ─────────────────────────────────────────────────────────────────────────
# Each block maps a compliance enum to an Asana custom field + option GID.
# Bootstrap via `npm run script -- scripts/asana-cf-bootstrap.ts`.
# All [STUB-OK] — missing GIDs silently drop the field from task payloads.

# Risk level (enum field)
ASANA_CF_RISK_LEVEL_GID=
ASANA_CF_RISK_LEVEL_CRITICAL=
ASANA_CF_RISK_LEVEL_HIGH=
ASANA_CF_RISK_LEVEL_MEDIUM=
ASANA_CF_RISK_LEVEL_LOW=

# Verdict (enum field)
ASANA_CF_VERDICT_GID=
ASANA_CF_VERDICT_PASS=
ASANA_CF_VERDICT_FLAG=
ASANA_CF_VERDICT_ESCALATE=
ASANA_CF_VERDICT_FREEZE=

# Case id (text field)
ASANA_CF_CASE_ID_GID=

# Deadline type (enum field)
ASANA_CF_DEADLINE_TYPE_GID=
ASANA_CF_DEADLINE_TYPE_STR=
ASANA_CF_DEADLINE_TYPE_CTR=
ASANA_CF_DEADLINE_TYPE_CNMR=
ASANA_CF_DEADLINE_TYPE_DPMSR=
ASANA_CF_DEADLINE_TYPE_EOCN=

# Numeric fields
ASANA_CF_DAYS_REMAINING_GID=
ASANA_CF_CONFIDENCE_GID=

# Text fields
ASANA_CF_REGULATION_GID=

# CDD push side-channel fields (added in this session — see
# src/services/cddAsanaCustomFieldPush.ts)
ASANA_CF_CUSTOMER_NAME_GID=
ASANA_CF_JURISDICTION_GID=
ASANA_CF_UBO_COUNT_GID=
ASANA_CF_PEP_FLAG_GID=


# ─────────────────────────────────────────────────────────────────────────
# Server-side authentication
# ─────────────────────────────────────────────────────────────────────────

# [REQUIRED FOR PRODUCTION] Bearer token for POST /api/brain.
# Generate with: openssl rand -hex 24
# MUST be set in BOTH Netlify env vars AND locally for the orchestrator.
# Same token authenticates the toast stream poller in the SPA.
HAWKEYE_BRAIN_TOKEN=REPLACE_ME_WITH_32_HEX_CHARS

# [REQUIRED FOR FOUR-EYES] At least 2 entries, comma-separated.
# Each entry: <user-id>:<32-hex-key>
# Generate keys with: openssl rand -hex 16
HAWKEYE_APPROVER_KEYS=user-mlro-primary:REPLACE_ME,user-mlro-deputy:REPLACE_ME

# [REQUIRED FOR PRODUCTION] Server-side signing secret.
# Generate with: openssl rand -hex 32
AUTH_SIGNING_SECRET=your-random-32-byte-hex-secret

# Public URL of the deployed brain endpoint.
HAWKEYE_BRAIN_URL=https://compliance-analyzer.netlify.app


# ─────────────────────────────────────────────────────────────────────────
# AI / LLM integration (optional)
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key


# ─────────────────────────────────────────────────────────────────────────
# Notification bridge (Tier 4 of the autopilot pass)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] Microsoft Teams incoming webhook URL. When unset, the
# notificationBridge silently drops Teams cards.
TEAMS_WEBHOOK_URL=

# [OPTIONAL] Email channel — the legacy workflow engine reads these.
EMAIL_SERVICE_URL=https://your-email-service-endpoint
EMAIL_FROM=compliance@yourcompany.com
EMAIL_TO_CO=compliance-officer@yourcompany.com


# ─────────────────────────────────────────────────────────────────────────
# Regulatory feeds (Tier D of the autopilot pass)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] EOCN sanctions feed URL. When unset, eocnDeltaWatcher returns
# zero deltas and the cron does nothing.
EOCN_FEED_URL=

# [STUB-OK] UAE FIU goAML portal API key — needed for the FIU
# acknowledgement auto-ingest path. Set to "STUB" for plan-only mode.
GOAML_PORTAL_API_KEY=
GOAML_PORTAL_BASE_URL=https://goaml.uaefiu.gov.ae/api


# ─────────────────────────────────────────────────────────────────────────
# Banking rail integration (Tier D — auto-freeze executor)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] Banking rail freeze API key. Without it, autoFreezeExecutor
# returns 'unconfigured' and the MLRO must freeze via the bank portal.
# Set to "STUB" for plan-only mode (returns the FreezePlan but doesn't
# call the real API).
BANKING_FREEZE_API_KEY=
BANKING_FREEZE_BASE_URL=https://banking-rail.example.com/freeze


# ─────────────────────────────────────────────────────────────────────────
# Spot price feeds (metals trading + Reuters Refinitiv adapter)
# ─────────────────────────────────────────────────────────────────────────

# [STUB-OK] Reuters Refinitiv pricing API. When unset the adapter
# returns 'unconfigured' and the price oracle stays on its 3 free
# aggregators.
REUTERS_REFINITIV_API_KEY=
REUTERS_REFINITIV_BASE_URL=https://api.refinitiv.com/data/pricing/v1

# [OPTIONAL] Free metals price API — uses 'demo' key with severe rate
# limits when unset.
METAL_PRICE_API_KEY=your-metalpriceapi-key


# ─────────────────────────────────────────────────────────────────────────
# Trading agents (optional)
# ─────────────────────────────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=your-hyperliquid-private-key
HYPERLIQUID_VAULT_ADDRESS=your-hyperliquid-vault-address
HYPERLIQUID_NETWORK=testnet


# ─────────────────────────────────────────────────────────────────────────
# Cachet status page (optional)
# ─────────────────────────────────────────────────────────────────────────
# CACHET_BASE_URL=https://status.example.com
# CACHET_API_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# GitHub integration (optional — used by managed agents)
# ─────────────────────────────────────────────────────────────────────────
# Fine-grained PAT scoped to repo + issues + pull_requests on the
# compliance-analyzer repo.
# GITHUB_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# Netlify (set automatically by Netlify, do not set locally)
# ─────────────────────────────────────────────────────────────────────────
# NETLIFY_BLOBS_CONTEXT=
