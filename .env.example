# ============================================================================
# Compliance Analyzer — Environment Variables
# ============================================================================
#
# Copy this file to `.env` for local development. For Netlify production,
# set each variable in: Site → Site settings → Environment variables.
# Or via CLI: `netlify env:set KEY value`
#
# Variables marked [REQUIRED] block boot. [OPTIONAL] degrade gracefully.
# Variables marked [STUB-OK] return a "not configured" status when absent
# instead of failing — the corresponding feature is dormant until set.
#
# After editing, validate with: `npm run test` (some env vars are checked
# at boot via src/utils/envCheck.ts).
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────
# CORE — Asana integration (all-tier baseline)
# ─────────────────────────────────────────────────────────────────────────

# [REQUIRED FOR ASANA] Personal access token for the Asana API.
# Get from: https://app.asana.com/0/my-apps
ASANA_TOKEN=your-asana-personal-access-token

# [OPTIONAL] Proxy URL when running the SPA against a Netlify-hosted Asana
# proxy. Leave blank to call Asana directly with ASANA_TOKEN.
ASANA_PROXY_URL=https://your-proxy.netlify.app

# [REQUIRED FOR CRONS] Workspace GID — used by the user resolver +
# scheduled monitoring functions.
ASANA_WORKSPACE_GID=

# [OPTIONAL] Default assignee for cron-created tasks (case-insensitive
# substring match against workspace user names).
ASANA_DEFAULT_ASSIGNEE_NAME=Luisa Fernanda

# ─────────────────────────────────────────────────────────────────────────
# Asana module projects — 19-project catalog (one board per compliance
# domain), locked with MLRO 2026-04-21. See docs/asana-workflow-spec.md
# for the event → project routing table.
#
# The stale GID 1213759768596515 previously pinned here for
# ASANA_SCREENINGS_PROJECT_GID was cleared on 2026-04-21 — that project
# does not exist in the canonical workspace (1213645083721316). Populate
# every slot below with the GID of the matching project in the
# "HAWKEYE STERLING V2" team.
# ─────────────────────────────────────────────────────────────────────────

# 1. Screening — Sanctions & Adverse Media
ASANA_SCREENINGS_PROJECT_GID=

# 2. Transaction Monitoring
ASANA_TM_PROJECT_GID=

# 3. STR/SAR/CTR/PMR — goAML Filings
ASANA_STR_PROJECT_GID=

# 4. CDD/SDD/EDD/KYC — Customer Due Diligence.
# The KYC expiry tracker project has been merged into CDD per MLRO
# decision (2026-04-21) — ASANA_KYC_CDD_TRACKER_PROJECT_GID below
# must point at the SAME GID as ASANA_CDD_PROJECT_GID.
ASANA_CDD_PROJECT_GID=

# 4b. KYC / CDD Expiry Tracker — same GID as ASANA_CDD_PROJECT_GID.
# Kept as a separate env var for backwards compatibility with the
# expiry-scan-cron and tm-scan-cron dispatchers.
ASANA_KYC_CDD_TRACKER_PROJECT_GID=

# 5. Supply Chain, ESG & LBMA Gold
ASANA_ESG_LBMA_PROJECT_GID=

# 6. Export Control & Dual-Use
ASANA_EXPORT_CONTROL_PROJECT_GID=

# 7. Compliance Governance — policy, RACI, committee, AI governance
# (merges the prior AI-governance slot; ASANA_AI_GOVERNANCE_PROJECT_GID
# below is deprecated and will be removed in a follow-up).
ASANA_GOVERNANCE_PROJECT_GID=

# DEPRECATED — use ASANA_GOVERNANCE_PROJECT_GID. The AI governance
# self-audit cron still reads this alias; it is safe to leave unset.
ASANA_AI_GOVERNANCE_PROJECT_GID=

# 8. Employees (new, split from the combined training slot below).
ASANA_EMPLOYEES_PROJECT_GID=

# 9. Training (new, split from the combined training slot below).
ASANA_TRAINING_PROJECT_GID=

# DEPRECATED combined slot — the MLRO split this into two separate
# projects on 2026-04-21 (ASANA_EMPLOYEES_PROJECT_GID +
# ASANA_TRAINING_PROJECT_GID). Dispatcher prefers the split vars but
# falls back to this one if neither split var is set.
ASANA_EMPLOYEES_TRAINING_PROJECT_GID=

# 10. Compliance Ops — Daily & Weekly Tasks (MLRO-owned human checklist).
ASANA_COMPLIANCE_TASKS_PROJECT_GID=

# 11. Four-Eyes Approvals Queue — every decision needing two approvers.
ASANA_FOUR_EYES_PROJECT_GID=

# 12. Shipments — Tracking (physical chain-of-custody).
ASANA_SHIPMENTS_PROJECT_GID=

# 13. FFR — Incidents & Asset Freezes.
# Confirmed sanctions matches, 24h EOCN freeze clock, CNMR filings
# (Cabinet Res 74/2020 Art.4-7).
ASANA_INCIDENTS_PROJECT_GID=

# 14. Incidents & Grievances — operational incidents, whistleblower,
# customer complaints (Fed Decree-Law 32/2021, FDL Art.29).
# DISTINCT from FFR above (different subject matter, different
# confidentiality regime).
ASANA_GRIEVANCES_PROJECT_GID=

# 15. Routines — Scheduled (the 33 cron functions and their dry-run
# reports; machine-driven, not human-driven).
ASANA_ROUTINES_PROJECT_GID=

# 16. MLRO Workbench — cross-module action surface.
ASANA_WORKBENCH_PROJECT_GID=

# 17. Regulator Portal Handoff — evidence packets for MoE / LBMA / EOCN.
ASANA_INSPECTOR_PROJECT_GID=

# 18. Central MLRO — Daily Digest — declared further down this file in
# the dedicated central-MLRO section.

# 19. Audit Log — 10-Year Trail — declared further down this file in
# the audit-log section. Optional; dispatcher falls back to Netlify
# Blobs auditChain if this GID is empty (FDL Art.24 still met).

# ─────────────────────────────────────────────────────────────────────────
# DROPPED from the 19-project catalog on 2026-04-21 — kept here as
# empty aliases so existing code that reads them does not crash, but
# the dispatcher no longer routes events to these slots:
#
#   - ASANA_ONBOARDING_PROJECT_GID      → routed into CDD/SDD/EDD/KYC
#   - ASANA_COUNTERPARTIES_PROJECT_GID  → routed into existing
#                                         "Customer Database" project
#                                         outside the 19 catalog
#   - ASANA_AUDIT_INSPECTION_PROJECT_GID→ folded into Regulator Portal
#                                         Handoff + Audit Log
#   - ASANA_DEFAULT_PROJECT_GID         → no catch-all; unrouted events
#                                         now log to auditChain only
# ─────────────────────────────────────────────────────────────────────────
ASANA_ONBOARDING_PROJECT_GID=
ASANA_COUNTERPARTIES_PROJECT_GID=
ASANA_AUDIT_INSPECTION_PROJECT_GID=
ASANA_DEFAULT_PROJECT_GID=


